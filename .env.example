# This file is a placeholder for environment variables required to run this project.
# Currently, there are no environment variables needed.

# Example of what future variables might look like:
# NEXT_PUBLIC_API_KEY=your_api_key_here
# DATABASE_URL=your_database_url_here
# SECRET_KEY=your_secret_key_here

# Password for protected pages/routes
PAGE_ACCESS_PASSWORD=password

# Password hash for the private people section.
# Generate with:
# node -e "const crypto=require('crypto'); const password='change-me'; const salt=crypto.randomBytes(16).toString('hex'); const hash=crypto.pbkdf2Sync(password, salt, 310000, 32, 'sha256').toString('hex'); console.log('ENEMIES_PASSWORD_SALT='+salt); console.log('ENEMIES_PASSWORD_HASH='+hash);"
ENEMIES_PASSWORD_SALT=your_random_salt
ENEMIES_PASSWORD_HASH=your_pbkdf2_sha256_hash
